{
    "name": "sloppy-sloths-server",
    "version": "1.0.0",
    "description": "",
    "license": "MIT",
    "author": "",
    "type": "module",
    "main": "index.ts",
    "engines": {
        "node": ">=20.6.0",
        "npm": ">=9.0.0"
    },
    "scripts": {
        "postinstall": "cp -n .env.template .env || true",
        "start": "tsx --env-file=.env index.ts",
        "seed": "tsx --env-file=.env src/seed.ts",
        "db:reset": "tsx --env-file=.env src/reset_db.ts",
        "test": "npm run test:unit && npm run test:integration",
        "test:unit": "NODE_OPTIONS='--experimental-vm-modules' node --env-file=.env node_modules/jest/bin/jest.js",
        "test:integration": "PGDATABASE=sloppy_sloths_test NODE_OPTIONS='--experimental-vm-modules' node --env-file=.env node_modules/jest/bin/jest.js --config jest.integration.config.ts --runInBand"
    },
    "dependencies": {
        "@fastify/multipart": "^10.0.0",
        "@fastify/rate-limit": "^10.3.0",
        "@fastify/type-provider-json-schema-to-ts": "^5.0.0",
        "fastify": "^5.8.5",
        "pg": "^8.21.0"
    },
    "devDependencies": {
        "@types/jest": "^29.5.14",
        "@types/node": "^25.9.1",
        "@types/pg": "^8.20.0",
        "jest": "^29.7.0",
        "ts-jest": "^29.2.6",
        "ts-node": "^10.9.2",
        "tsx": "^4.22.4",
        "typescript": "^5.8.2"
    }
}
